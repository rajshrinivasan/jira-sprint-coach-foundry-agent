# Azure AI Foundry project endpoint
# Found in: AI Foundry portal > your project > Overview > Project details
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# The model deployment name inside your Foundry project
MODEL_DEPLOYMENT_NAME=gpt-4.1

# --- Real Jira integration (for production use) ---
# These would be read by server.py to authenticate against Jira REST API.
# They are NOT used by the simulated server — uncomment when replacing with real API calls.
# JIRA_BASE_URL=https://<your-org>.atlassian.net
# JIRA_API_TOKEN=<your-jira-api-token>
# JIRA_USER_EMAIL=<your-atlassian-email>
# JIRA_BOARD_ID=<your-board-id>
